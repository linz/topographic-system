{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "place_point",
  "description": "Represents a named place or locality.",
  "type": "object",
  "required": [
    "topo_id",
    "feature_type",
    "capture_method",
    "change_type",
    "update_date",
    "create_date",
    "version",
    "geometry"
  ],
  "properties": {
    "topo_id": {
      "type": "string",
      "description": "The unique identifier for the topographic feature."
    },
    "t50_fid": {
      "type": "integer",
      "description": "The unique identifier for the feature in the source database.",
      "precision": 64
    },
    "feature_type": {
      "type": "string",
      "description": "The specific type of feature being represented (e.g., 'bridge_line', 'building').",
      "maxLength": 50
    },
    "place_type": {
      "type": "string",
      "description": "The type of the feature.",
      "maxLength": 11
    },
    "status": {
      "type": "string",
      "description": "",
      "maxLength": 25
    },
    "name": {
      "type": "string",
      "description": "The name of the feature.",
      "maxLength": 75
    },
    "elevation": {
      "type": "integer",
      "description": "",
      "precision": 32
    },
    "composition": {
      "type": "string",
      "description": "",
      "maxLength": 9
    },
    "description": {
      "type": "string",
      "description": "",
      "maxLength": 80
    },
    "orientation": {
      "type": "number",
      "description": ""
    },
    "substance": {
      "type": "string",
      "description": "",
      "maxLength": 11
    },
    "capture_method": {
      "type": "string",
      "description": "The method used to capture the data (e.g., 'manual','automated').",
      "maxLength": 25
    },
    "change_type": {
      "type": "string",
      "description": "The type of change that occurred to the feature (e.g., 'new', 'updated').",
      "maxLength": 25
    },
    "update_date": {
      "type": "string",
      "description": "The date when the feature was last updated in the database."
    },
    "create_date": {
      "type": "string",
      "description": "The date when the feature was created in the database."
    },
    "version": {
      "type": "integer",
      "description": "The version of the feature.",
      "precision": 32
    },
    "geometry": {
      "type": "point",
      "description": "The geometry of the feature."
    }
  }
}