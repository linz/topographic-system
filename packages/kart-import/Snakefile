import logging
from kart_import.log import log_context
from kart_import.config import (
    get_themes,
    get_releases,
    get_datasets,
    get_kart_repos,
    get_dataset_name,
    DATASET_MAP,
    DATASET_TO_THEME_MAP,
)
from kart_import.assets.clone import clone_dataset
from kart_import.assets.fid_lifecycle import generate_lifecycle
from kart_import.assets.export import export_dataset_releases
from kart_import.assets.transform import transform_dataset_release
from kart_import.assets.theme import merge_theme_release
from kart_import.assets.kart_import import kart_import_repo
from kart_import.assets.bundle import bundle_dataset

# Load configuration details from the Python package
THEMES = get_themes()
RELEASES = get_releases()
DATASETS = get_datasets()
REPOS = get_kart_repos()
THEME_MAP = {t.name: t for t in THEMES}


# TARGETS
ALL_IMPORTED = [f"data/output/{repo}/.imported" for repo in REPOS]

rule all:
    input:
        ALL_IMPORTED


# 1. CLONE
rule clone:
    output:
        cloned = "data/source/{dataset}/.cloned"
    run:
        with log_context(action="clone", dataset=wildcards.dataset):
            clone_dataset(wildcards.dataset)


# 2. LIFECYCLE
rule lifecycle:
    input:
        cloned = "data/source/{dataset}/.cloned"
    output:
        lifecycle = "data/working/lifecycle/{dataset}_release" + f"{RELEASES[0].id}-{RELEASES[-1].id}.json"
    run:
        with log_context(action="lifecycle", dataset=wildcards.dataset):
            generate_lifecycle(wildcards.dataset)


# 3. EXPORT RELEASES (Produces all release files for a dataset at once)
rule export:
    input:
        cloned = "data/source/{dataset}/.cloned"
    output:
        files = [f"data/working/export/release_{r.id}/{{dataset}}.json" for r in RELEASES]
    run:
        with log_context(action="export", dataset=wildcards.dataset):
            export_dataset_releases(wildcards.dataset)


# 4. TRANSFORM
rule transform:
    input:
        lifecycle = "data/working/lifecycle/{dataset}_release" + f"{RELEASES[0].id}-{RELEASES[-1].id}.json",
        exported = "data/working/export/release_{release}/{dataset}.json"
    output:
        transformed = "data/working/transform/release_{release}/{dataset}.json"
    run:
        with log_context(action="transform", dataset=wildcards.dataset, release=wildcards.release):
            transform_dataset_release(wildcards.dataset, int(wildcards.release), wait_for_release=True)


# 5. THEME RELEASE (Merges datasets for a single release)
rule theme_release:
    input:
        transformed = lambda wildcards: [
            f"data/working/transform/release_{wildcards.release}/{ds.name}.json"
            for ds in THEME_MAP[wildcards.theme].datasets
        ]
    output:
        merged = "data/working/theme/release_{release}/{theme}.geojson"
    run:
        with log_context(action="theme", theme=wildcards.theme, release=wildcards.release):
            merge_theme_release(wildcards.theme, int(wildcards.release))


# 6. KART IMPORT (Performs chronological imports into a target repository)
rule kart_import:
    input:
        themes = lambda wildcards: [
            f"data/working/theme/release_{r.id}/{t.name}.geojson"
            for t in THEMES if t.target_repo == wildcards.repo
            for r in RELEASES
        ]
    output:
        imported = "data/output/{repo}/.imported"
    run:
        with log_context(action="kart_import", repo=wildcards.repo):
            kart_import_repo(wildcards.repo)


# 7. UTILITY BUNDLE RULE
rule bundle:
    output:
        sentinel = "data/source/{dataset}/.bundle_created"
    run:
        with log_context(action="bundle", dataset=wildcards.dataset):
            bundle_dataset(wildcards.dataset)


# --- DYNAMIC CONVENIENCE ALIASES (automated from config files in a loop) ---

# Dataset Clones
for name in DATASET_MAP:
    workflow.rule(name=f"clone_{name}")(
        workflow.input(f"data/source/{name}/.cloned")(
            workflow.run(lambda *args, **kwargs: None)
        )
    )

# Themes
for t in THEMES:
    workflow.rule(name=f"theme_{t.name}")(
        workflow.input([f"data/working/theme/release_{r.id}/{t.name}.geojson" for r in RELEASES])(
            workflow.run(lambda *args, **kwargs: None)
        )
    )

# Kart Imports
for repo in REPOS:
    safe_repo_name = repo.replace("-", "_")
    workflow.rule(name=f"kart_import_{safe_repo_name}")(
        workflow.input(f"data/output/{repo}/.imported")(
            workflow.run(lambda *args, **kwargs: None)
        )
    )

