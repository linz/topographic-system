from kart_import.config import (
    get_themes,
    get_releases,
    get_kart_repos,
    DATASET_MAP,
    DATASET_TO_THEME_MAP,
    TRANSFORM_SUFFIX,
    LOOKUP_TO_THEME_MAP,
)

import os
import uuid

# Load configuration details from the Python package
THEMES = get_themes()
RELEASES = get_releases()
REPOS = get_kart_repos()
THEME_MAP = {t.name: t for t in THEMES}

# Generate a single Trace ID for this entire Snakemake run so all distributed logs link together
if "TRACEPARENT" not in os.environ:
    run_trace_id = uuid.uuid4().hex
    run_span_id = uuid.uuid4().hex[:16]
    os.environ["TRACEPARENT"] = f"00-{run_trace_id}-{run_span_id}-01"

# Per-invocation run id (the trace id, whether generated above or inherited). Used to
# scope log files so each run's logs live in their own directory and match the `TraceId`
# embedded in every JSON log record. `ls -t logs/bundle/` finds the latest run.
RUN_ID = os.environ["TRACEPARENT"].split("-")[1]


# TARGETS
ALL_IMPORTED = [f"data/output/{repo}/.imported" for repo in REPOS]

rule all:
    input:
        ALL_IMPORTED


# 1. CLONE
rule clone:
    output:
        cloned = "data/source/{dataset}/.cloned"
    shell:
        "uv run python -m kart_import.assets.clone {wildcards.dataset}"


# 2. LIFECYCLE
rule lifecycle:
    input:
        cloned = "data/source/{dataset}/.cloned",
        config = lambda wildcards: f"config/themes/{DATASET_TO_THEME_MAP[wildcards.dataset].name}.yml"
    output:
        lifecycle = "data/working/lifecycle/{dataset}_release" + f"{RELEASES[0].id}-{RELEASES[-1].id}.json"
    shell:
        "uv run python -m kart_import.assets.fid_lifecycle {wildcards.dataset}"


# 3a. EXPORT RELEASES (Produces all release files for a dataset at once)
rule export:
    input:
        cloned = "data/source/{dataset}/.cloned"
    output:
        files = [f"data/working/export/release_{r.id}/{{dataset}}.json" for r in RELEASES]
    shell:
        "uv run python -m kart_import.assets.export {wildcards.dataset}"


# 3b. EXPORT LOOKUP (one export of full lookup source per distinct commit across releases; not per release)
rule export_lookup:
    input:
        cloned = "data/source/{lookup}/.cloned"
    output:
        exported = directory("data/working/export/lookup/{lookup}")
    shell:
        "uv run python -m kart_import.assets.export --lookup {wildcards.lookup}"


# 3c. PREPARE LOOKUPS (slim derived lookup table per commit that will be joined into datasets)
rule prepare_lookup:
    input:
        exported = "data/working/export/lookup/{lookup}",
        config = lambda wildcards: f"config/themes/{LOOKUP_TO_THEME_MAP[wildcards.lookup].name}.yml"
    output:
        prepared = directory("data/working/lookup/{lookup}")
    shell:
        "uv run python -m kart_import.assets.prepare {wildcards.lookup}"


# 4. TRANSFORM
rule transform:
    input:
        lifecycle = "data/working/lifecycle/{dataset}_release" + f"{RELEASES[0].id}-{RELEASES[-1].id}.json",
        exported = "data/working/export/release_{release}/{dataset}.json",
        config = lambda wildcards: f"config/themes/{DATASET_TO_THEME_MAP[wildcards.dataset].name}.yml",
        fixups = lambda wildcards: (
            ["src/kart_import/fixups.py"] if DATASET_MAP[wildcards.dataset].fixups else []
        ),
        lookups = lambda wildcards: [
            f"data/working/lookup/{join.lookup}"
            for join in DATASET_MAP[wildcards.dataset].joins
        ],
        # clone must be present (not just the prepared parquet).
        lookup_clones = lambda wildcards: [
            f"data/source/{join.lookup}/.cloned"
            for join in DATASET_MAP[wildcards.dataset].joins
        ]
    output:
        transformed = "data/working/transform/release_{release}/{dataset}" + TRANSFORM_SUFFIX
    shell:
        "uv run python -m kart_import.assets.transform {wildcards.dataset} {wildcards.release}"


# 5. THEME RELEASE (Merges datasets for a single release)
rule theme_release:
    input:
        config = "config/themes/{theme}.yml",
        transformed = lambda wildcards: [
            f"data/working/transform/release_{wildcards.release}/{ds.name}{TRANSFORM_SUFFIX}"
            for ds in THEME_MAP[wildcards.theme].datasets
        ]
    output:
        merged = "data/working/theme/release_{release}/{theme}.geojson"
    shell:
        "uv run python -m kart_import.assets.theme {wildcards.theme} {wildcards.release}"

rule kart_theme:
    input:
        themes = lambda wildcards: [
            f"data/working/theme/release_{r.id}/{wildcards.theme}.geojson"
            for r in RELEASES
        ]
    output:
        imported = "data/output/{theme}.bundle"
    shell:
        "uv run python -m kart_import.assets.kart_import_theme {wildcards.theme}"

rule kart_repo:
    input:
        themes = lambda wildcards: [
            f"data/output/{t.name}.bundle"
            for t in THEMES if t.target_repo == wildcards.repo
        ]
    output:
        imported = "data/output/{repo}/.imported"
    shell:
        "uv run python -m kart_import.assets.kart_import_repo {wildcards.repo}"


# 7. UTILITY BUNDLE RULE
rule bundle:
    output:
        sentinel = "data/source/{dataset}/.bundle_created"
    log:
        # Per-dataset, per-run log so parallel jobs don't interleave, runs don't clobber
        # each other, and failures are easy to isolate:
        #   grep -l '"SeverityText": "ERROR"' logs/bundle/$RUN_ID/*.log
        # The {RUN_ID} directory matches the `TraceId` in every JSON log record.
        f"logs/bundle/{RUN_ID}/{{dataset}}.log"
    shell:
        "uv run python -m kart_import.assets.bundle {wildcards.dataset} > {log} 2>&1"



for name in DATASET_MAP:
    workflow.rule(name=f"clone_{name}")(
        workflow.input(f"data/source/{name}/.cloned")(
            workflow.run(lambda *args, **kwargs: None)
        )
    )

workflow.rule(name="clone_all")(
    workflow.input([f"data/source/{name}/.cloned" for name in DATASET_MAP])(
        workflow.run(lambda *args, **kwargs: None)
    )
)

workflow.rule(name="bundle_all")(
    workflow.input([f"data/source/{name}/.bundle_created" for name in DATASET_MAP])(
        workflow.run(lambda *args, **kwargs: None)
    )
)

for t in THEMES:
    workflow.rule(name=f"theme_{t.name}")(
        workflow.input([f"data/working/theme/release_{r.id}/{t.name}.geojson" for r in RELEASES])(
            workflow.run(lambda *args, **kwargs: None)
        )
    )

    workflow.rule(name=f"kart_theme_{t.name}")(
        workflow.input(f"data/output/{t.name}.bundle")(
            workflow.run(lambda *args, **kwargs: None)
        )
    )

workflow.rule(name="kart_theme_all")(
    workflow.input([f"data/output/{t.name}.bundle" for t in THEMES])(
        workflow.run(lambda *args, **kwargs: None)
    )
)

for repo in REPOS:
    safe_repo_name = repo.replace("-", "_")
    workflow.rule(name=f"kart_import_{safe_repo_name}")(
        workflow.input(f"data/output/{repo}/.imported")(
            workflow.run(lambda *args, **kwargs: None)
        )
    )
