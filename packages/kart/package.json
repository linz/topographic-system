{
  "name": "@linzjs/topographic-system-kart",
  "version": "0.9.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "test": "node --test \"src/**/*.test.ts\"",
    "test:container": "node --test \"src/**/*.test.container.ts\"",
    "bundle": "esbuild src/index.ts --bundle --platform=node --sourcemap --target=node24 --outfile=dist/index.cjs",
    "build:container": "npm run bundle && docker buildx build ../../ --file ./Dockerfile -t ts-kart"
  },
  "dependencies": {
    "@linzjs/topographic-system-shared": "^0.8.0",
    "@linzjs/topographic-system-stac": "^0.7.0",
    "cmd-ts": "^0.14.3",
    "fast-xml-parser": "^5.5.11",
    "zx": "^8.8.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "ajv": "^8.18.0",
    "js-yaml": "^4.1.1"
  }
}
