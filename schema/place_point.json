{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "place_point",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID for the feature."
    },
    "updated_at": {
      "type": "object",
      "properties": {}
    },
    "created_at": {
      "type": "object",
      "properties": {},
      "description": "Default at write time: today."
    },
    "t50_fid": {},
    "type": {
      "anyOf": [
        {
          "type": "string",
          "const": "cave"
        },
        {
          "type": "string",
          "const": "cemetery"
        },
        {
          "type": "string",
          "const": "grave"
        },
        {
          "type": "string",
          "const": "historic_site"
        },
        {
          "type": "string",
          "const": "mine"
        },
        {
          "type": "string",
          "const": "monument"
        },
        {
          "type": "string",
          "const": "pa"
        },
        {
          "type": "string",
          "const": "radar_dome"
        },
        {
          "type": "string",
          "const": "saddle"
        },
        {
          "type": "string",
          "const": "satellite_station"
        },
        {
          "type": "null"
        }
      ]
    },
    "place_type": {
      "anyOf": [
        {
          "$ref": "#/$defs/PlaceTypeEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/StatusEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "elevation": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": -2147483648,
          "maximum": 2147483647
        },
        {
          "type": "null"
        }
      ]
    },
    "composition": {
      "anyOf": [
        {
          "$ref": "#/$defs/CompositionEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "orientation": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "substance_extracted": {
      "anyOf": [
        {
          "$ref": "#/$defs/SubstanceEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "geometry": {
      "description": "WKB geometry. Validation only checks presence + non-null; semantic checks live elsewhere.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox"
    }
  },
  "required": ["id", "updated_at", "created_at", "geometry"],
  "additionalProperties": false,
  "$defs": {
    "PlaceTypeEnum": {
      "type": "string",
      "enum": ["opencast", "underground"],
      "description": "Auto-derived from observed values of `place_type`."
    },
    "StatusEnum": {
      "type": "string",
      "enum": [
        "closed",
        "dangerous",
        "derelict",
        "disused",
        "historic",
        "locked",
        "old",
        "private",
        "remains",
        "ruins",
        "under construction"
      ],
      "description": "Auto-derived from observed values of `status`."
    },
    "CompositionEnum": {
      "type": "string",
      "enum": ["limestone", "pumice"],
      "description": "Auto-derived from observed values of `composition`."
    },
    "SubstanceEnum": {
      "type": "string",
      "enum": [
        "bentonite",
        "clay",
        "coal",
        "gold",
        "gravel",
        "ironsand",
        "lime",
        "limestone",
        "metal",
        "quartz",
        "scheelite",
        "shingle",
        "silica sand",
        "silver",
        "stone",
        "zeolite"
      ],
      "description": "Auto-derived from observed values of `substance`."
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  }
}
