{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "water",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID for the feature."
    },
    "updated_at": {
      "type": "object",
      "properties": {}
    },
    "created_at": {
      "type": "object",
      "properties": {},
      "description": "Default at write time: today."
    },
    "t50_fid": {},
    "type": {
      "anyOf": [
        {
          "type": "string",
          "const": "canal"
        },
        {
          "type": "string",
          "const": "lagoon"
        },
        {
          "type": "string",
          "const": "lake"
        },
        {
          "type": "string",
          "const": "pond"
        },
        {
          "type": "string",
          "const": "river"
        },
        {
          "type": "null"
        }
      ]
    },
    "water_use": {
      "anyOf": [
        {
          "$ref": "#/$defs/WaterUseEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "hierarchy": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "group_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "nzgb_feat_id": {},
    "height": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "elevation": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": -2147483648,
          "maximum": 2147483647
        },
        {
          "type": "null"
        }
      ]
    },
    "perennial": {
      "anyOf": [
        {
          "$ref": "#/$defs/PerennialEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "temperature": {
      "anyOf": [
        {
          "$ref": "#/$defs/TemperatureEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "geometry": {
      "description": "WKB geometry. Validation only checks presence + non-null; semantic checks live elsewhere.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox"
    }
  },
  "required": ["id", "updated_at", "created_at", "geometry"],
  "additionalProperties": false,
  "$defs": {
    "WaterUseEnum": {
      "type": "string",
      "enum": [
        "evaporation",
        "hydro-electric",
        "ice skating",
        "oil",
        "oxidation",
        "reservoir",
        "settling",
        "sewage",
        "sewage treatment",
        "sludge"
      ],
      "description": "Auto-derived from observed values of `water_use`."
    },
    "PerennialEnum": {
      "type": "string",
      "enum": ["dry", "seasonal"],
      "description": "Auto-derived from observed values of `perennial`."
    },
    "TemperatureEnum": {
      "type": "string",
      "enum": ["hot"],
      "description": "Auto-derived from observed values of `temperature`."
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  }
}
