{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "building_point",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID for the feature."
    },
    "updated_at": {
      "type": "object",
      "properties": {}
    },
    "created_at": {
      "type": "object",
      "properties": {},
      "description": "Default at write time: today."
    },
    "t50_fid": {},
    "type": {
      "anyOf": [
        {
          "type": "string",
          "const": "building"
        },
        {
          "type": "null"
        }
      ]
    },
    "building_use": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/StatusEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "orientation": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "geometry": {
      "description": "WKB geometry. Validation only checks presence + non-null; semantic checks live elsewhere.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox"
    }
  },
  "required": ["id", "updated_at", "created_at", "geometry"],
  "additionalProperties": false,
  "$defs": {
    "StatusEnum": {
      "type": "string",
      "enum": [
        "closed",
        "dangerous",
        "derelict",
        "disused",
        "historic",
        "locked",
        "old",
        "private",
        "remains",
        "ruins",
        "under construction"
      ],
      "description": "Auto-derived from observed values of `status`."
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  }
}
