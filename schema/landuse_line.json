{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "landuse_line",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID for the feature."
    },
    "updated_at": {
      "type": "object",
      "properties": {}
    },
    "created_at": {
      "type": "object",
      "properties": {},
      "description": "Default at write time: today."
    },
    "t50_fid": {},
    "type": {
      "type": "string",
      "const": "racetrack"
    },
    "landuse_use": {
      "anyOf": [
        {
          "$ref": "#/$defs/LanduseUseEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "subtype": {
      "anyOf": [
        {
          "$ref": "#/$defs/LanduseSubTypeEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "geometry": {
      "description": "WKB geometry. Validation only checks presence + non-null; semantic checks live elsewhere.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox"
    }
  },
  "required": ["id", "updated_at", "created_at", "type", "geometry"],
  "additionalProperties": false,
  "$defs": {
    "LanduseUseEnum": {
      "type": "string",
      "enum": ["cycle", "dog", "horse", "vehicle"],
      "description": "Auto-derived from observed values of `landuse_use`."
    },
    "LanduseSubTypeEnum": {
      "type": "string",
      "enum": ["opencast", "training"],
      "description": "Auto-derived from observed values of `subtype`."
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  }
}
