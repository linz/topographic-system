{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "structure_point",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID for the feature."
    },
    "updated_at": {
      "type": "object",
      "properties": {}
    },
    "created_at": {
      "type": "object",
      "properties": {},
      "description": "Default at write time: today."
    },
    "t50_fid": {},
    "type": {
      "anyOf": [
        {
          "type": "string",
          "const": "beacon"
        },
        {
          "type": "string",
          "const": "bivouac"
        },
        {
          "type": "string",
          "const": "buoy"
        },
        {
          "type": "string",
          "const": "chimney"
        },
        {
          "type": "string",
          "const": "dredge"
        },
        {
          "type": "string",
          "const": "flare"
        },
        {
          "type": "string",
          "const": "floodgate"
        },
        {
          "type": "string",
          "const": "gate"
        },
        {
          "type": "string",
          "const": "ladder"
        },
        {
          "type": "string",
          "const": "mast"
        },
        {
          "type": "string",
          "const": "redoubt"
        },
        {
          "type": "string",
          "const": "shaft"
        },
        {
          "type": "string",
          "const": "siphon"
        },
        {
          "type": "string",
          "const": "stockyard"
        },
        {
          "type": "string",
          "const": "tank"
        },
        {
          "type": "string",
          "const": "tower"
        },
        {
          "type": "string",
          "const": "well"
        },
        {
          "type": "string",
          "const": "windmill"
        },
        {
          "type": "string",
          "const": "wreck"
        },
        {
          "type": "null"
        }
      ]
    },
    "structure_use": {
      "anyOf": [
        {
          "$ref": "#/$defs/StructureUseEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "subtype": {
      "anyOf": [
        {
          "$ref": "#/$defs/StructureSubTypeEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/StatusEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "location": {
      "anyOf": [
        {
          "$ref": "#/$defs/LocationEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "height": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "orientation": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "material": {
      "anyOf": [
        {
          "$ref": "#/$defs/MaterialEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "restrictions": {
      "anyOf": [
        {
          "$ref": "#/$defs/RestrictionsEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "stored_item": {
      "anyOf": [
        {
          "$ref": "#/$defs/StoredItemEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "wreck_of": {
      "anyOf": [
        {
          "$ref": "#/$defs/WreckOfEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "geometry": {
      "description": "WKB geometry. Validation only checks presence + non-null; semantic checks live elsewhere.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox"
    }
  },
  "required": ["id", "updated_at", "created_at", "geometry"],
  "additionalProperties": false,
  "$defs": {
    "StructureUseEnum": {
      "type": "string",
      "enum": ["historic", "jetty", "power generation", "tunnel ventilation"],
      "description": "Auto-derived from observed values of `structure_use`."
    },
    "StructureSubTypeEnum": {
      "type": "string",
      "enum": ["lighthouse", "surge chamber", "uncovered", "water"],
      "description": "Auto-derived from observed values of `subtype`."
    },
    "StatusEnum": {
      "type": "string",
      "enum": [
        "closed",
        "dangerous",
        "derelict",
        "disused",
        "historic",
        "locked",
        "old",
        "private",
        "remains",
        "ruins",
        "under construction"
      ],
      "description": "Auto-derived from observed values of `status`."
    },
    "LocationEnum": {
      "type": "string",
      "enum": ["lake", "land", "sea"],
      "description": "Auto-derived from observed values of `location`."
    },
    "MaterialEnum": {
      "type": "string",
      "enum": ["concrete", "rock"],
      "description": "Auto-derived from observed values of `material`."
    },
    "RestrictionsEnum": {
      "type": "string",
      "enum": ["locked"],
      "description": "Auto-derived from observed values of `restrictions`."
    },
    "StoredItemEnum": {
      "type": "string",
      "enum": ["fuel", "water"],
      "description": "Auto-derived from observed values of `stored_item`."
    },
    "WreckOfEnum": {
      "type": "string",
      "enum": ["plane", "ship"],
      "description": "Auto-derived from observed values of `wreck_of`."
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  }
}
