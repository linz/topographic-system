{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "structure_line",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID for the feature."
    },
    "updated_at": {
      "type": "object",
      "properties": {}
    },
    "created_at": {
      "type": "object",
      "properties": {},
      "description": "Default at write time: today."
    },
    "t50_fid": {},
    "type": {
      "anyOf": [
        {
          "type": "string",
          "const": "boatramp"
        },
        {
          "type": "string",
          "const": "boom"
        },
        {
          "type": "string",
          "const": "breakwater"
        },
        {
          "type": "string",
          "const": "cableway_industrial"
        },
        {
          "type": "string",
          "const": "cableway_people"
        },
        {
          "type": "string",
          "const": "dam"
        },
        {
          "type": "string",
          "const": "flume"
        },
        {
          "type": "string",
          "const": "ladder"
        },
        {
          "type": "string",
          "const": "marine_farm"
        },
        {
          "type": "string",
          "const": "ski_lift"
        },
        {
          "type": "string",
          "const": "ski_tow"
        },
        {
          "type": "string",
          "const": "slipway"
        },
        {
          "type": "string",
          "const": "spillway_edge"
        },
        {
          "type": "string",
          "const": "walkwire"
        },
        {
          "type": "string",
          "const": "water_race"
        },
        {
          "type": "string",
          "const": "weir"
        },
        {
          "type": "string",
          "const": "wharf"
        },
        {
          "type": "string",
          "const": "wharf_edge"
        },
        {
          "type": "null"
        }
      ]
    },
    "structure_use": {
      "anyOf": [
        {
          "$ref": "#/$defs/StructureUseEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "species": {
      "anyOf": [
        {
          "$ref": "#/$defs/SpeciesEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/StatusEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "material": {
      "anyOf": [
        {
          "$ref": "#/$defs/MaterialEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "material_conveyed": {
      "anyOf": [
        {
          "$ref": "#/$defs/MaterialConveyedEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "restrictions": {
      "anyOf": [
        {
          "$ref": "#/$defs/RestrictionsEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "geometry": {
      "description": "WKB geometry. Validation only checks presence + non-null; semantic checks live elsewhere.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox"
    }
  },
  "required": ["id", "updated_at", "created_at", "geometry"],
  "additionalProperties": false,
  "$defs": {
    "StructureUseEnum": {
      "type": "string",
      "enum": ["historic", "jetty", "power generation", "tunnel ventilation"],
      "description": "Auto-derived from observed values of `structure_use`."
    },
    "SpeciesEnum": {
      "type": "string",
      "enum": ["mussels", "salmon"],
      "description": "Auto-derived from observed values of `species`."
    },
    "StatusEnum": {
      "type": "string",
      "enum": [
        "closed",
        "dangerous",
        "derelict",
        "disused",
        "historic",
        "locked",
        "old",
        "private",
        "remains",
        "ruins",
        "under construction"
      ],
      "description": "Auto-derived from observed values of `status`."
    },
    "MaterialEnum": {
      "type": "string",
      "enum": ["concrete", "rock"],
      "description": "Auto-derived from observed values of `material`."
    },
    "MaterialConveyedEnum": {
      "type": "string",
      "enum": ["coal", "lime"],
      "description": "Auto-derived from observed values of `material_conveyed`."
    },
    "RestrictionsEnum": {
      "type": "string",
      "enum": ["locked"],
      "description": "Auto-derived from observed values of `restrictions`."
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  }
}
