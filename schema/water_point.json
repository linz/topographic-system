{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "water_point",
  "type": "object",
  "properties": {
    "topo_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID without braces. Unique identifier for the feature."
    },
    "fid": {},
    "capture_method": {
      "$ref": "#/$defs/CaptureMethod",
      "default": "manual",
      "description": "How the feature was captured."
    },
    "change_type": {
      "$ref": "#/$defs/ChangeType",
      "default": "new",
      "description": "What kind of change this row represents."
    },
    "update_date": {
      "type": "string",
      "format": "date",
      "description": "Must be on or after create_date. Default at write time: today.",
      "formatMinimum": {
        "$data": "1/create_date"
      }
    },
    "create_date": {
      "type": "string",
      "format": "date",
      "description": "Default at write time: today."
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483647,
      "default": 1,
      "description": "Lifecycle counter; increments on each update."
    },
    "t50_fid": {},
    "feature_type": {
      "anyOf": [
        {
          "type": "string",
          "const": "rock"
        },
        {
          "type": "string",
          "const": "soakhole"
        },
        {
          "type": "string",
          "const": "spring"
        },
        {
          "type": "string",
          "const": "swamp"
        },
        {
          "type": "string",
          "const": "waterfall"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "height": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "orientation": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "temperature_indicator": {
      "anyOf": [
        {
          "$ref": "#/$defs/TemperatureIndicatorEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "geometry": {
      "description": "WKB geometry. Validation only checks presence + non-null; semantic checks live elsewhere.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox"
    }
  },
  "required": ["topo_id", "fid", "capture_method", "change_type", "update_date", "create_date", "version", "geometry"],
  "additionalProperties": false,
  "$defs": {
    "CaptureMethod": {
      "type": "string",
      "enum": ["manual", "automated", "surveyed"],
      "description": "How the feature was captured."
    },
    "ChangeType": {
      "type": "string",
      "enum": ["new", "modified attributes", "modified geometry", "modified geometry and attributes"],
      "description": "Lifecycle change type for a feature row."
    },
    "TemperatureIndicatorEnum": {
      "type": "string",
      "enum": ["cold", "hot"],
      "description": "Auto-derived from observed values of `temperature_indicator`."
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  }
}
