{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "landuse",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID for the feature."
    },
    "updated_at": {
      "type": "object",
      "properties": {}
    },
    "created_at": {
      "type": "object",
      "properties": {},
      "description": "Default at write time: today."
    },
    "t50_fid": {},
    "type": {
      "anyOf": [
        {
          "type": "string",
          "const": "cemetery"
        },
        {
          "type": "string",
          "const": "golf_course"
        },
        {
          "type": "string",
          "const": "gravel_pit"
        },
        {
          "type": "string",
          "const": "landfill"
        },
        {
          "type": "string",
          "const": "mine"
        },
        {
          "type": "string",
          "const": "orchard"
        },
        {
          "type": "string",
          "const": "pumice_pit"
        },
        {
          "type": "string",
          "const": "quarry"
        },
        {
          "type": "string",
          "const": "racetrack"
        },
        {
          "type": "string",
          "const": "rifle_range"
        },
        {
          "type": "string",
          "const": "showground"
        },
        {
          "type": "string",
          "const": "sportsfield"
        },
        {
          "type": "string",
          "const": "vineyard"
        },
        {
          "type": "null"
        }
      ]
    },
    "landuse_use": {
      "anyOf": [
        {
          "$ref": "#/$defs/LanduseUseEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "subtype": {
      "anyOf": [
        {
          "$ref": "#/$defs/LanduseSubTypeEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/StatusEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "substance_extracted": {
      "anyOf": [
        {
          "$ref": "#/$defs/SubstanceEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "geometry": {
      "description": "WKB geometry. Validation only checks presence + non-null; semantic checks live elsewhere.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox"
    }
  },
  "required": ["id", "updated_at", "created_at", "geometry"],
  "additionalProperties": false,
  "$defs": {
    "LanduseUseEnum": {
      "type": "string",
      "enum": ["cycle", "dog", "horse", "vehicle"],
      "description": "Auto-derived from observed values of `landuse_use`."
    },
    "LanduseSubTypeEnum": {
      "type": "string",
      "enum": ["opencast", "training"],
      "description": "Auto-derived from observed values of `subtype`."
    },
    "StatusEnum": {
      "type": "string",
      "enum": [
        "closed",
        "dangerous",
        "derelict",
        "disused",
        "historic",
        "locked",
        "old",
        "private",
        "remains",
        "ruins",
        "under construction"
      ],
      "description": "Auto-derived from observed values of `status`."
    },
    "SubstanceEnum": {
      "type": "string",
      "enum": [
        "bentonite",
        "clay",
        "coal",
        "gold",
        "gravel",
        "ironsand",
        "lime",
        "limestone",
        "metal",
        "quartz",
        "scheelite",
        "shingle",
        "silica sand",
        "silver",
        "stone",
        "zeolite"
      ],
      "description": "Auto-derived from observed values of `substance`."
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  }
}
