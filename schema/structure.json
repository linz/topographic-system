{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "structure",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID for the feature."
    },
    "updated_at": {
      "type": "object",
      "properties": {}
    },
    "created_at": {
      "type": "object",
      "properties": {},
      "description": "Default at write time: today."
    },
    "t50_fid": {},
    "type": {
      "anyOf": [
        {
          "type": "string",
          "const": "dry_dock"
        },
        {
          "type": "string",
          "const": "fish_farm"
        },
        {
          "type": "string",
          "const": "marine_farm"
        },
        {
          "type": "string",
          "const": "reservoir"
        },
        {
          "type": "string",
          "const": "siphon"
        },
        {
          "type": "string",
          "const": "tank"
        }
      ]
    },
    "lid_type": {
      "anyOf": [
        {
          "$ref": "#/$defs/LidTypeEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "subtype": {
      "anyOf": [
        {
          "$ref": "#/$defs/StructureSubTypeEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "species": {
      "anyOf": [
        {
          "$ref": "#/$defs/SpeciesEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/StatusEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "stored_item": {
      "anyOf": [
        {
          "$ref": "#/$defs/StoredItemEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "geometry": {
      "description": "WKB geometry. Validation only checks presence + non-null; semantic checks live elsewhere.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox"
    }
  },
  "required": ["id", "updated_at", "created_at", "type", "geometry"],
  "additionalProperties": false,
  "$defs": {
    "LidTypeEnum": {
      "type": "string",
      "enum": ["covered"],
      "description": "Auto-derived from observed values of `lid_type`."
    },
    "StructureSubTypeEnum": {
      "type": "string",
      "enum": ["lighthouse", "surge chamber", "uncovered", "water"],
      "description": "Auto-derived from observed values of `subtype`."
    },
    "SpeciesEnum": {
      "type": "string",
      "enum": ["mussels", "salmon"],
      "description": "Auto-derived from observed values of `species`."
    },
    "StatusEnum": {
      "type": "string",
      "enum": [
        "closed",
        "dangerous",
        "derelict",
        "disused",
        "historic",
        "locked",
        "old",
        "private",
        "remains",
        "ruins",
        "under construction"
      ],
      "description": "Auto-derived from observed values of `status`."
    },
    "StoredItemEnum": {
      "type": "string",
      "enum": ["fuel", "water"],
      "description": "Auto-derived from observed values of `stored_item`."
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  }
}
