{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tunnel_line",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID for the feature."
    },
    "updated_at": {
      "type": "object",
      "properties": {}
    },
    "created_at": {
      "type": "object",
      "properties": {},
      "description": "Default at write time: today."
    },
    "t50_fid": {},
    "type": {
      "type": "string",
      "const": "tunnel"
    },
    "tunnel_use": {
      "anyOf": [
        {
          "$ref": "#/$defs/TunnelUseEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "tunnel_use2": {
      "anyOf": [
        {
          "$ref": "#/$defs/TunnelUse2Enum"
        },
        {
          "type": "null"
        }
      ]
    },
    "subtype": {
      "anyOf": [
        {
          "$ref": "#/$defs/TunnelSubTypeEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/StatusEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "geometry": {
      "description": "WKB geometry. Validation only checks presence + non-null; semantic checks live elsewhere.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox"
    }
  },
  "required": ["id", "updated_at", "created_at", "type", "geometry"],
  "additionalProperties": false,
  "$defs": {
    "TunnelUseEnum": {
      "type": "string",
      "enum": ["cablecar", "foot traffic", "livestock", "river", "train", "tram", "vehicle"],
      "description": "Auto-derived from observed values of `tunnel_use`."
    },
    "TunnelUse2Enum": {
      "type": "string",
      "enum": ["livestock"],
      "description": "Auto-derived from observed values of `tunnel_use2`."
    },
    "TunnelSubTypeEnum": {
      "type": "string",
      "enum": ["natural"],
      "description": "Auto-derived from observed values of `subtype`."
    },
    "StatusEnum": {
      "type": "string",
      "enum": [
        "closed",
        "dangerous",
        "derelict",
        "disused",
        "historic",
        "locked",
        "old",
        "private",
        "remains",
        "ruins",
        "under construction"
      ],
      "description": "Auto-derived from observed values of `status`."
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  }
}
