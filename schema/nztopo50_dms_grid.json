{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nztopo50_dms_grid",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID for the feature."
    },
    "direction": {
      "anyOf": [
        {
          "$ref": "#/$defs/DirectionEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "value": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "geometry": {
      "description": "WKB geometry. Validation only checks presence + non-null; semantic checks live elsewhere.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox"
    }
  },
  "required": ["id", "geometry"],
  "additionalProperties": false,
  "$defs": {
    "DirectionEnum": {
      "type": "string",
      "enum": ["x", "y"],
      "description": "Auto-derived from observed values of `direction`."
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  }
}
