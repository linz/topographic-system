{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "next/structure_line",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "UUIDv7 of the feature"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO Datetime of when the feature was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO Datetime of when the feature was last updated"
    },
    "t50_fid": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295
        },
        {
          "type": "null"
        }
      ],
      "description": "Reference topo50 feature ID.\n\nWill be null if the feature is new and has not been published in a Topo50 edition."
    },
    "type": {
      "$ref": "#/$defs/structure_line_type"
    },
    "structure_use": {
      "anyOf": [
        {
          "$ref": "#/$defs/structure_line_use"
        },
        {
          "type": "null"
        }
      ]
    },
    "species": {
      "anyOf": [
        {
          "$ref": "#/$defs/structure_line_species"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/structure_line_status"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "material": {
      "anyOf": [
        {
          "$ref": "#/$defs/structure_line_material"
        },
        {
          "type": "null"
        }
      ]
    },
    "material_conveyed": {
      "anyOf": [
        {
          "$ref": "#/$defs/structure_line_material_conveyed"
        },
        {
          "type": "null"
        }
      ]
    },
    "restrictions": {
      "anyOf": [
        {
          "$ref": "#/$defs/structure_line_restrictions"
        },
        {
          "type": "null"
        }
      ]
    },
    "geometry": {
      "description": "GeoParquet 1.1 covering geometry struct.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox",
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  },
  "required": [
    "id",
    "created_at",
    "updated_at",
    "t50_fid",
    "type",
    "structure_use",
    "species",
    "status",
    "name",
    "material",
    "material_conveyed",
    "restrictions",
    "geometry"
  ],
  "additionalProperties": false,
  "$defs": {
    "structure_line_type": {
      "type": "string",
      "enum": [
        "boatramp",
        "boom",
        "breakwater",
        "cableway_industrial",
        "cableway_people",
        "dam",
        "flume",
        "ladder",
        "marine_farm",
        "ski_lift",
        "ski_tow",
        "slipway",
        "spillway_edge",
        "walkwire",
        "water_race",
        "weir",
        "wharf",
        "wharf_edge"
      ]
    },
    "structure_line_use": {
      "type": "string",
      "enum": ["disused", "historic", "jetty", "power generation", "tunnel ventilation"]
    },
    "structure_line_species": {
      "type": "string",
      "enum": ["mussels", "salmon"]
    },
    "structure_line_status": {
      "type": "string",
      "enum": [
        "closed",
        "dangerous",
        "derelict",
        "disused",
        "historic",
        "locked",
        "old",
        "private",
        "remains",
        "ruins",
        "under construction"
      ]
    },
    "structure_line_material": {
      "type": "string",
      "enum": ["concrete", "rock"]
    },
    "structure_line_material_conveyed": {
      "type": "string",
      "enum": ["coal", "lime"]
    },
    "structure_line_restrictions": {
      "type": "string",
      "enum": ["locked"]
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  }
}
