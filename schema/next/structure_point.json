{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "next/structure_point",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "UUIDv7 of the feature"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO Datetime of when the feature was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO Datetime of when the feature was last updated"
    },
    "t50_fid": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295
        },
        {
          "type": "null"
        }
      ],
      "description": "Reference topo50 feature ID.\n\nWill be null if the feature is new and has not been published in a Topo50 edition."
    },
    "type": {
      "$ref": "#/$defs/structure_point_type"
    },
    "subtype": {
      "anyOf": [
        {
          "$ref": "#/$defs/structure_subtype"
        },
        {
          "type": "null"
        }
      ]
    },
    "tank_type": {
      "anyOf": [
        {
          "$ref": "#/$defs/structure_tank_type"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/structure_status"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "location": {
      "anyOf": [
        {
          "type": "string",
          "const": "land"
        },
        {
          "type": "string",
          "const": "lake"
        },
        {
          "type": "string",
          "const": "sea"
        },
        {
          "type": "null"
        }
      ]
    },
    "height": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "orientation": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "geometry": {
      "description": "GeoParquet 1.1 covering geometry struct.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox",
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  },
  "required": [
    "id",
    "created_at",
    "updated_at",
    "t50_fid",
    "type",
    "subtype",
    "tank_type",
    "status",
    "name",
    "location",
    "height",
    "orientation",
    "geometry"
  ],
  "additionalProperties": false,
  "$defs": {
    "structure_point_type": {
      "type": "string",
      "enum": [
        "beacon",
        "bivouac",
        "buoy",
        "chimney",
        "dredge",
        "flare",
        "floodgate",
        "gate",
        "ladder",
        "mast",
        "radar_dome",
        "redoubt",
        "satellite_station",
        "shaft",
        "siphon",
        "stockyard",
        "tank",
        "tower",
        "well",
        "windmill",
        "wreck"
      ]
    },
    "structure_subtype": {
      "type": "string",
      "enum": [
        "building",
        "coal",
        "concrete",
        "disused",
        "fuel",
        "historic",
        "jetty",
        "lighthouse",
        "lime",
        "locked",
        "plane",
        "power_generation",
        "rock",
        "ship",
        "surge_chamber",
        "tunnel_ventilation",
        "uncovered",
        "water"
      ]
    },
    "structure_tank_type": {
      "type": "string",
      "enum": ["uncovered", "water", "surge_chamber"]
    },
    "structure_status": {
      "type": "string",
      "enum": [
        "closed",
        "dangerous",
        "derelict",
        "disused",
        "historic",
        "locked",
        "old",
        "private",
        "remains",
        "ruins",
        "under_construction"
      ]
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  }
}
