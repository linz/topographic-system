{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "next/tunnel_line",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "UUIDv7 of the feature"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "t50_fid": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295
        },
        {
          "type": "null"
        }
      ],
      "description": "Reference topo50 feature ID.\n\nWill be null if the feature is new and has not been published in a Topo50 edition."
    },
    "type": {
      "type": "string",
      "const": "tunnel"
    },
    "tunnel_use": {
      "anyOf": [
        {
          "$ref": "#/$defs/tunnel_use"
        },
        {
          "type": "null"
        }
      ]
    },
    "tunnel_use2": {
      "anyOf": [
        {
          "$ref": "#/$defs/tunnel_use"
        },
        {
          "type": "null"
        }
      ]
    },
    "subtype": {
      "anyOf": [
        {
          "$ref": "#/$defs/tunnel_subtype"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/tunnel_status"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "metadata": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DataSource"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "geometry": {
      "description": "GeoParquet 1.1 covering geometry struct.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox",
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  },
  "required": [
    "id",
    "created_at",
    "updated_at",
    "t50_fid",
    "type",
    "tunnel_use",
    "tunnel_use2",
    "subtype",
    "status",
    "name",
    "metadata",
    "geometry"
  ],
  "additionalProperties": false,
  "$defs": {
    "tunnel_use": {
      "type": "string",
      "enum": ["cablecar", "foot traffic", "livestock", "river", "train", "tram", "vehicle"]
    },
    "tunnel_subtype": {
      "type": "string",
      "enum": ["natural"]
    },
    "tunnel_status": {
      "type": "string",
      "enum": ["closed", "under construction"]
    },
    "DataSource": {
      "type": "object",
      "properties": {
        "table_column": {
          "type": "string",
          "description": "Name of the column in this table where the linked data gets copied to"
        },
        "source": {
          "$ref": "#/$defs/metadata_source",
          "description": "Registered source for linked data"
        },
        "source_key_name": {
          "type": "string",
          "description": "Name of the key column in source to use for linking"
        },
        "source_key_value": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 4294967295
            },
            {
              "type": "string"
            }
          ],
          "description": "Value of the key column in source to use for linking."
        },
        "source_table": {
          "type": "string",
          "description": "Name of the table in source that contains the linked data"
        },
        "source_column": {
          "type": "string",
          "description": "Name of the column in the source where the linked data gets copied from"
        },
        "source_updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the source was last updated"
        },
        "imported_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when this linked data was last imported"
        }
      },
      "required": [
        "table_column",
        "source",
        "source_key_name",
        "source_key_value",
        "source_table",
        "source_column",
        "source_updated_at",
        "imported_at"
      ],
      "additionalProperties": false
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct.",
      "additionalProperties": false
    },
    "metadata_source": {
      "type": "string",
      "enum": ["nzgb_gazetteer", "linz_aims"]
    }
  }
}
