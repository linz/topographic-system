{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "road_line",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID for the feature."
    },
    "updated_at": {
      "type": "object",
      "properties": {}
    },
    "created_at": {
      "type": "object",
      "properties": {},
      "description": "Default at write time: today."
    },
    "t50_fid": {},
    "type": {
      "anyOf": [
        {
          "type": "string",
          "const": "road"
        },
        {
          "type": "null"
        }
      ]
    },
    "hierarchy": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/StatusEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "highway_number": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "lane_count": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": -2147483648,
          "maximum": 2147483647
        },
        {
          "type": "null"
        }
      ]
    },
    "surface": {
      "anyOf": [
        {
          "$ref": "#/$defs/SurfaceEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "way_count": {
      "anyOf": [
        {
          "$ref": "#/$defs/WayCountEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "width_indicator": {
      "anyOf": [
        {
          "type": "string",
          "const": "w"
        },
        {
          "type": "null"
        }
      ]
    },
    "road_access": {
      "anyOf": [
        {
          "$ref": "#/$defs/RoadAccessEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "name_id": {},
    "rna_sufi": {},
    "geometry": {
      "description": "WKB geometry. Validation only checks presence + non-null; semantic checks live elsewhere.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox"
    }
  },
  "required": ["id", "updated_at", "created_at", "geometry"],
  "additionalProperties": false,
  "$defs": {
    "StatusEnum": {
      "type": "string",
      "enum": [
        "closed",
        "dangerous",
        "derelict",
        "disused",
        "historic",
        "locked",
        "old",
        "private",
        "remains",
        "ruins",
        "under construction"
      ],
      "description": "Auto-derived from observed values of `status`."
    },
    "SurfaceEnum": {
      "type": "string",
      "enum": ["grass", "metalled", "sealed", "unmetalled"],
      "description": "Auto-derived from observed values of `surface`."
    },
    "WayCountEnum": {
      "type": "string",
      "enum": ["one way"],
      "description": "Auto-derived from observed values of `way_count`."
    },
    "RoadAccessEnum": {
      "type": "string",
      "enum": ["mp"],
      "description": "Auto-derived from observed values of `road_access`."
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  }
}
