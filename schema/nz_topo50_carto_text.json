    },
    "FontEnum": {
      "type": "string",
      "enum": ["", "Nimbus Sans"],
      "description": "Auto-derived from observed values of `font`."
    },
    "StyleEnum": {
      "type": "string",
      "enum": ["", "Italic", "Narrow", "Narrow Bold", "Narrow Oblique", "Regular"],
      "description": "Auto-derived from observed values of `style`."
    },
    "ColourEnum": {
      "type": "string",
      "enum": ["", "black", "steelblue", "red"],
      "description": "Auto-derived from observed values of `colour`."
    },
    "PlacementEnum": {
      "type": "string",
      "enum": ["", "AL", "BL", "OL"],
      "description": "Auto-derived from observed values of `placement`."
    },
    "TextanchorEnum": {
      "type": "string",
      "enum": ["", "centre", "left", "left ", "left 0.62", "right"],
      "description": "Auto-derived from observed values of `textanchor`."
    },
    "CharplaceEnum": {
      "type": "string",
      "enum": ["", "CharactersAtVertices", "StretchCharacterSpacingToFit", "StretchWordSpacingToFit"],
      "description": "Auto-derived from observed values of `charplace`."
