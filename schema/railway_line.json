{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "railway_line",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID for the feature."
    },
    "updated_at": {
      "type": "object",
      "properties": {}
    },
    "created_at": {
      "type": "object",
      "properties": {},
      "description": "Default at write time: today."
    },
    "t50_fid": {},
    "type": {
      "type": "string",
      "const": "railway"
    },
    "railway_use": {
      "anyOf": [
        {
          "$ref": "#/$defs/RailwayUseEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "track_type": {
      "anyOf": [
        {
          "$ref": "#/$defs/TrackTypeEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "vehicle_type": {
      "anyOf": [
        {
          "$ref": "#/$defs/VehicleTypeEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/StatusEnum"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "nzgb_id": {},
    "route": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "route2": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "route3": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "geometry": {
      "description": "WKB geometry. Validation only checks presence + non-null; semantic checks live elsewhere.",
      "not": {
        "type": "null"
      }
    },
    "bbox": {
      "$ref": "#/$defs/BBox"
    }
  },
  "required": ["id", "updated_at", "created_at", "type", "geometry"],
  "additionalProperties": false,
  "$defs": {
    "RailwayUseEnum": {
      "type": "string",
      "enum": ["siding"],
      "description": "Auto-derived from observed values of `railway_use`."
    },
    "TrackTypeEnum": {
      "type": "string",
      "enum": ["connector", "multiple", "route", "single"],
      "description": "Auto-derived from observed values of `track_type`."
    },
    "VehicleTypeEnum": {
      "type": "string",
      "enum": ["cablecar", "rail cart", "train", "tram"],
      "description": "Auto-derived from observed values of `vehicle_type`."
    },
    "StatusEnum": {
      "type": "string",
      "enum": [
        "closed",
        "dangerous",
        "derelict",
        "disused",
        "historic",
        "locked",
        "old",
        "private",
        "remains",
        "ruins",
        "under construction"
      ],
      "description": "Auto-derived from observed values of `status`."
    },
    "BBox": {
      "type": "object",
      "properties": {
        "xmin": {
          "type": "number"
        },
        "ymin": {
          "type": "number"
        },
        "xmax": {
          "type": "number"
        },
        "ymax": {
          "type": "number"
        }
      },
      "required": ["xmin", "ymin", "xmax", "ymax"],
      "description": "GeoParquet 1.1 covering bbox struct."
    }
  }
}
