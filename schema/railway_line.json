{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "railway_line",
    "type": "object",
    "properties": {
        "topo_id": {
            "type": "string",
            "description": "UUID for the feature."
        },
        "capture_method": {
            "$ref": "#/$defs/CaptureMethod",
            "default": "manual",
            "description": "How the feature was captured."
        },
        "change_type": {
            "$ref": "#/$defs/ChangeType",
            "default": "new",
            "description": "What kind of change this row represents."
        },
        "update_date": {
            "type": "object",
            "properties": {},
            "description": "Should be on or after create_date."
        },
        "create_date": {
            "type": "object",
            "properties": {},
            "description": "Default at write time: today."
        },
        "version": {
            "type": "integer",
            "minimum": 1,
            "maximum": 2147483647,
            "default": 1,
            "description": "Lifecycle counter; increments on each update."
        },
        "t50_fid": {},
        "feature_type": {
            "anyOf": [
                {
                    "type": "string",
                    "const": "railway"
                },
                {
                    "type": "null"
                }
            ]
        },
        "railway_use": {
            "anyOf": [
                {
                    "$ref": "#/$defs/RailwayUseEnum"
                },
                {
                    "type": "null"
                }
            ]
        },
        "track_type": {
            "anyOf": [
                {
                    "$ref": "#/$defs/TrackTypeEnum"
                },
                {
                    "type": "null"
                }
            ]
        },
        "vehicle_type": {
            "anyOf": [
                {
                    "$ref": "#/$defs/VehicleTypeEnum"
                },
                {
                    "type": "null"
                }
            ]
        },
        "status": {
            "anyOf": [
                {
                    "$ref": "#/$defs/StatusEnum"
                },
                {
                    "type": "null"
                }
            ]
        },
        "name": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ]
        },
        "nzgb_id": {},
        "route": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ]
        },
        "route2": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ]
        },
        "route3": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ]
        },
        "geometry": {
            "description": "WKB geometry. Validation only checks presence + non-null; semantic checks live elsewhere.",
            "not": {
                "type": "null"
            }
        },
        "bbox": {
            "$ref": "#/$defs/BBox"
        }
    },
    "required": [
        "topo_id",
        "capture_method",
        "change_type",
        "update_date",
        "create_date",
        "version",
        "geometry"
    ],
    "additionalProperties": false,
    "$defs": {
        "CaptureMethod": {
            "type": "string",
            "enum": [
                "manual",
                "automated",
                "surveyed"
            ],
            "description": "How the feature was captured."
        },
        "ChangeType": {
            "type": "string",
            "enum": [
                "new",
                "update",
                "modified attributes",
                "modified geometry",
                "modified geometry and attributes"
            ],
            "description": "Lifecycle change type for a feature row."
        },
        "RailwayUseEnum": {
            "type": "string",
            "enum": [
                "siding"
            ],
            "description": "Auto-derived from observed values of `railway_use`."
        },
        "TrackTypeEnum": {
            "type": "string",
            "enum": [
                "connector",
                "multiple",
                "route",
                "single"
            ],
            "description": "Auto-derived from observed values of `track_type`."
        },
        "VehicleTypeEnum": {
            "type": "string",
            "enum": [
                "cablecar",
                "rail cart",
                "train",
                "tram"
            ],
            "description": "Auto-derived from observed values of `vehicle_type`."
        },
        "StatusEnum": {
            "type": "string",
            "enum": [
                "closed",
                "dangerous",
                "derelict",
                "disused",
                "historic",
                "locked",
                "old",
                "private",
                "remains",
                "ruins",
                "under construction"
            ],
            "description": "Auto-derived from observed values of `status`."
        },
        "BBox": {
            "type": "object",
            "properties": {
                "xmin": {
                    "type": "number"
                },
                "ymin": {
                    "type": "number"
                },
                "xmax": {
                    "type": "number"
                },
                "ymax": {
                    "type": "number"
                }
            },
            "required": [
                "xmin",
                "ymin",
                "xmax",
                "ymax"
            ],
            "description": "GeoParquet 1.1 covering bbox struct."
        }
    }
}