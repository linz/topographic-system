{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "AuditFields.json",
    "type": "object",
    "properties": {
        "capture_method": {
            "$ref": "#/$defs/CaptureMethod",
            "default": "manual",
            "description": "How the feature was captured."
        },
        "change_type": {
            "$ref": "#/$defs/ChangeType",
            "default": "new",
            "description": "What kind of change this row represents."
        },
        "update_date": {
            "type": "object",
            "properties": {},
            "description": "Should be on or after create_date."
        },
        "create_date": {
            "type": "object",
            "properties": {},
            "description": "Default at write time: today."
        },
        "version": {
            "type": "integer",
            "minimum": 1,
            "maximum": 2147483647,
            "default": 1,
            "description": "Lifecycle counter; increments on each update."
        }
    },
    "required": [
        "capture_method",
        "change_type",
        "update_date",
        "create_date",
        "version"
    ],
    "description": "Capture / change-tracking columns shared by most features.",
    "$defs": {
        "CaptureMethod": {
            "type": "string",
            "enum": [
                "manual",
                "automated",
                "surveyed"
            ],
            "description": "How the feature was captured."
        },
        "ChangeType": {
            "type": "string",
            "enum": [
                "new",
                "update",
                "modified attributes",
                "modified geometry",
                "modified geometry and attributes"
            ],
            "description": "Lifecycle change type for a feature row."
        }
    }
}