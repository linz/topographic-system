{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "trailingComma": "all",
  "singleQuote": true,
  "printWidth": 120,
  "useTabs": false,
  "tabWidth": 2,
  "endOfLine": "lf",
  "sortPackageJson": false,
  "ignorePatterns": ["CHANGELOG.md", "pyproject.toml", "build/", "node_modules/"],
  "experimentalSortImports": {
    "newlinesBetweenGroups": true
  }
}
